{
  "name": "cofactor-memory",
  "version": "0.1.0",
  "description": "Local-first catalytic memory for Markdown corpora and AI agents.",
  "type": "module",
  "license": "MIT",
  "author": "jayhack",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayhack/cofactor.git"
  },
  "bugs": {
    "url": "https://github.com/jayhack/cofactor/issues"
  },
  "homepage": "https://jayhack.github.io/cofactor/",
  "keywords": [
    "agents",
    "ai",
    "knowledge-base",
    "markdown",
    "memory",
    "notes",
    "rag",
    "semantic-search"
  ],
  "bin": {
    "cofactor": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage .cofactor test-output",
    "dev": "tsx src/cli.ts",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.0.0",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public"
  }
}
